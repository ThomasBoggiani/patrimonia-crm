# ═══════════════════════════════════════════════════════════════════
# PATRIMONIA CRM — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════
# Copier ce fichier en .env.local pour le dev local (jamais commité)
# Renseigner les mêmes variables dans Vercel pour la production
#
# Toutes les variables NEXT_PUBLIC_* sont exposées côté navigateur.
# Les autres restent côté serveur.
# ═══════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────
# SUPABASE — Base de données et authentification
# ─────────────────────────────────────────────────────────────────

# URL publique du projet Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme publique (Dashboard → Settings → API → anon public)
# Utilisée par le frontend pour les appels Supabase user-scoped
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...

# Clé service-role privée (Dashboard → Settings → API → service_role)
# ⚠️ NE JAMAIS exposer côté client. Bypass RLS.
# Utilisée par les routes /api/* pour les opérations privilégiées
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiI...

# Secret pour les webhooks Supabase entrants (cron, triggers DB)
# Validé côté serveur pour authentifier les appels
SUPABASE_WEBHOOK_SECRET=un_secret_aleatoire_long_et_unique


# ─────────────────────────────────────────────────────────────────
# ANTHROPIC — Claude (IA principale)
# ─────────────────────────────────────────────────────────────────

# Clé API Anthropic (console.anthropic.com)
# Utilisée par : assistant Patrimonia, analyse mandat, génération emails
ANTHROPIC_API_KEY=sk-ant-...


# ─────────────────────────────────────────────────────────────────
# OPENAI — Whisper STT (transcription vocale)
# ─────────────────────────────────────────────────────────────────

# Clé API OpenAI (platform.openai.com)
# Utilisée UNIQUEMENT pour Whisper (transcription audio → texte)
# Le reste des appels IA passe par Anthropic
OPENAI_API_KEY=sk-...


# ─────────────────────────────────────────────────────────────────
# MICROSOFT GRAPH — Intégration Outlook (mail, calendrier, contacts)
# ─────────────────────────────────────────────────────────────────

# Azure AD App credentials (portal.azure.com)
MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────
# GOOGLE MAPS — Geocoding, Street View, Maps Static
# ─────────────────────────────────────────────────────────────────

# Clé API Google Maps (console.cloud.google.com)
# Utilisée pour : géocodage adresses, Street View, plans satellites
GOOGLE_MAPS_API_KEY=AIzaSy...


# ─────────────────────────────────────────────────────────────────
# DROPBOX — Picker pour les documents mandats (optionnel)
# ─────────────────────────────────────────────────────────────────

# App Key Dropbox (dropbox.com/developers/apps)
# Si vide, le bouton "Choisir depuis Dropbox" n'apparaît pas
NEXT_PUBLIC_DROPBOX_APP_KEY=xxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────
# WEBHOOKS ENTRANTS — Réception leads depuis le site WordPress
# ─────────────────────────────────────────────────────────────────

# Secret pour le webhook WordPress legacy
# Header X-Webhook-Secret attendu par /api/leads/wordpress
WORDPRESS_WEBHOOK_SECRET=un_secret_aleatoire_long_et_unique

# Clé API pour les routes leads modernes (alerte, contact, estimation, intérêt-bien)
# Header X-Api-Key attendu par /api/leads/*
SITE_WEBHOOK_API_KEY=un_secret_aleatoire_long_et_unique

# Origine autorisée pour les CORS des routes leads
# Ex: https://immeubles-patrimoine.fr
SITE_ALLOWED_ORIGIN=https://immeubles-patrimoine.fr


# ─────────────────────────────────────────────────────────────────
# URL DE L'APPLICATION
# ─────────────────────────────────────────────────────────────────

# URL canonique de l'app (pour les liens dans les emails, plaquettes, etc.)
# Dev : http://localhost:3000
# Prod : https://patrimonia-crm.vercel.app
NEXT_PUBLIC_APP_URL=https://patrimonia-crm.vercel.app

# ⚠️ DOUBLON HISTORIQUE — utilisé par quelques routes (à fusionner avec NEXT_PUBLIC_APP_URL)
# Mettre la même valeur pour l'instant
NEXT_PUBLIC_SITE_URL=https://patrimonia-crm.vercel.app
